{
    "_version": "1.12.0",
    "sap.app": {
        "id": "com.demo.processorder",
        "type": "application",
        "i18n": "i18n/i18n.properties",
        "applicationVersion": {
            "version": "1.0.0"
        }
    },
    "sap.ui5": {
        "rootView": {
            "viewName": "com.demo.processorder.view.Resource",
            "type": "XML",
            "async": true
        },
        "dependencies": {
            "minUI5Version": "1.71",
            "libs": {
                "sap.m": {},
                "sap.ui.layout": {}
            }
        },
        "routing": {
            "config": {
                "routerClass": "sap.m.routing.Router",
                "viewType": "XML",
                "viewPath": "com.demo.processorder.view",
                "controlId": "app",
                "controlAggregation": "pages",
                "bypassed": {
                    "target": "Resource"
                }
            },
            "routes": [
                {
                    "pattern": "",
                    "name": "Resource",
                    "target": "Resource"
                },
                {
                    "pattern": "order",
                    "name": "Order",
                    "target": "Order"
                },
                {
                    "pattern": "confirm",
                    "name": "Confirm",
                    "target": "Confirm"
                }
            ],
            "targets": {
                "Resource": {
                    "viewName": "Resource"
                },
                "Order": {
                    "viewName": "Order"
                },
                "Confirm": {
                    "viewName": "Confirm"
                }
            }
        }
    }
}
